{
  "version": 2,
  "buildCommand": "echo OK",
  "outputDirectory": "praxis-pro/público",
  "functions": {
    "praxis-pro/API/claude.js": {
      "runtime": "edge"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/praxis-pro/API/$1" },
    { "source": "/(.*)",     "destination": "/praxis-pro/público/index.html" }
  ]
}
